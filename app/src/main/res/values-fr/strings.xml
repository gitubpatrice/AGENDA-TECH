    <string name="about_badge_no_account">Zéro compte</string>

    <!-- À propos · Fonctionnalités -->
    <string name="about_features_title">Fonctionnalités</string>
    <string name="about_feat_views_label">Vues Mois, Semaine, Jour et Agenda</string>
    <string name="about_feat_views_desc">Balayez d\'un mois à l\'autre, revenez à aujourd\'hui, gérez plusieurs calendriers.</string>
    <string name="about_feat_recurrence_label">Événements récurrents</string>
    <string name="about_feat_recurrence_desc">Du quotidien à l\'annuel, intervalles personnalisés, date de fin — modifiez une seule occurrence ou toute la série.</string>
    <string name="about_feat_reminders_label">Rappels</string>
    <string name="about_feat_reminders_desc">Alarmes exactes, délai personnalisé, votre propre sonnerie. Reprogrammés après un redémarrage.</string>
    <string name="about_feat_import_label">Import / export</string>
    <string name="about_feat_import_desc">Copiez les événements déjà sur ce téléphone (Google, Exchange…) ou échangez des fichiers .ics — le tout hors ligne.</string>
    <string name="about_feat_widgets_label">Widgets écran d\'accueil</string>
    <string name="about_feat_widgets_desc">Vos prochains événements, et une icône date compacte.</string>
    <string name="about_feat_lock_label">Verrou PIN / biométrie</string>
    <string name="about_feat_lock_desc">Verrouillage optionnel de toute l\'app, avec protection anti-force-brute.</string>
    <string name="about_feat_encryption_label">Stockage chiffré</string>
    <string name="about_feat_encryption_desc">Toute la base est chiffrée en AES-256 ; la clé ne quitte jamais le matériel sécurisé de l\'appareil.</string>
    <string name="about_feat_theme_label">Thèmes clair et sombre</string>
    <string name="about_feat_theme_desc">Suit le système, ou forcez-en un. Numéros de semaine, début de semaine, couleur par défaut.</string>

    <!-- À propos · Sécurité -->
    <string name="about_security_title">Sécurité</string>
    <string name="about_security_card_title">Chiffré au repos</string>
    <string name="about_security_body">La base (SQLCipher, AES-256) est chiffrée par une clé aléatoire enveloppée par l\'AndroidKeyStore — matérielle et non exportable sur les appareils dotés d\'un élément sécurisé. Sans votre téléphone, le fichier est illisible. Les captures d\'écran et l\'aperçu dans les Récents sont bloqués par défaut, et les sauvegardes cloud sont désactivées : votre agenda n\'est jamais recopié hors de l\'appareil.</string>

    <!-- À propos · Permissions -->
    <string name="about_permissions_title">Permissions et pourquoi</string>
    <string name="about_perm_read_calendar">Lecture seule. Sert uniquement à copier, à votre demande, les événements déjà présents sur ce téléphone. Jamais d\'écriture, jamais d\'envoi.</string>
    <string name="about_perm_notifications">Afficher vos rappels.</string>
    <string name="about_perm_exact_alarm">Déclencher un rappel à la minute près — un rappel d\'agenda en retard ne sert à rien.</string>
    <string name="about_perm_boot">Reprogrammer vos rappels après un redémarrage (les alarmes n\'y survivent pas).</string>
    <string name="about_perm_vibrate">Vibrer lors d\'un rappel, si vous l\'activez.</string>
    <string name="about_perm_no_internet_name">INTERNET — non demandée</string>
    <string name="about_perm_no_internet">L\'app n\'a aucune permission réseau. Les liens de cette page s\'ouvrent dans votre navigateur, en dehors de l\'app.</string>

