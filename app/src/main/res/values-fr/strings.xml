    <!-- À propos · Confidentialité -->
    <string name="about_privacy_title">Confidentialité</string>
    <string name="about_privacy_card_title">100 % privé — zéro surveillance</string>
    <string name="about_privacy_body">Votre agenda ne quitte jamais ce téléphone. L\'app ne déclare aucune permission Internet — elle est techniquement incapable d\'envoyer quoi que ce soit où que ce soit.</string>
    <string name="about_badge_no_network">Zéro réseau</string>
