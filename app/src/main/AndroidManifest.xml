<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      DOCTRINE Agenda Tech : agenda 100 % LOCAL, chiffré, ZÉRO réseau.
      Aucune permission INTERNET / ACCESS_NETWORK_STATE n'est déclarée — et ne doit
      jamais l'être. L'interopérabilité se fait par import/export de fichiers .ics
      (RFC 5545) via le sélecteur de fichiers système, pas par synchronisation réseau.
    -->

    <!--
      androidx.work (tiré transitivement par Glance, pour les widgets) déclare
      ACCESS_NETWORK_STATE afin de servir ses contraintes réseau (NetworkType). Agenda Tech
      n'enfile aucun travail contraint par le réseau, donc la permission n'a rien à couvrir
      ici — mais sans ce retrait elle apparaissait bel et bien dans le manifeste fusionné, et
      donc dans la liste des permissions visible par l'utilisateur : la promesse « zéro réseau »
      affichée dans le README et sur files-tech.com était contredite par l'APK lui-même.
      Elle ne donne pas l'accès réseau (c'est INTERNET, absente) — le retrait est une question
      de cohérence vérifiable, pas de fuite.

      Pourquoi le retrait est sûr : WorkManager ne consulte l'état du réseau que pour honorer une
      contrainte NetworkType, et l'app n'enfile AUCUN travail WorkManager (vérifié : aucune
      référence à WorkManager/Constraints/NetworkType dans app/src/main). Glance ne pose pas non
      plus de contrainte réseau sur la mise à jour d'un widget.

      Vérifié sur appareil (S24, 15/07/2026) : les deux widgets posés sur l'écran d'accueil se
      lient et s'affichent, sans SecurityException. Si un jour du travail contraint par le réseau
      est ajouté, ce retrait devra être reconsidéré — mais ce serait déjà une entorse à la doctrine.
    -->
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:node="remove" />

    <!--
      Import ponctuel des événements déjà synchronisés localement sur l'appareil
      (agenda Google, Exchange, etc.) via le Calendar Provider Android (CalendarContract).
      LECTURE SEULE, 100 % LOCALE : Agenda Tech ne fait que lire ce que le système a déjà
      stocké sur le téléphone — AUCUNE connexion réseau, aucun accès au compte Google.
      La synchronisation distante reste gérée par les apps système. Permission dangereuse,
      demandée à l'exécution UNIQUEMENT quand l'utilisateur ouvre l'écran d'import.
    -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- Rappels (notifications) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Alarmes exactes des rappels.
         USE_EXACT_ALARM (Android 13+) : auto-accordée pour une app dont la fonction
         centrale est agenda/alarme (pas de dialogue utilisateur). SCHEDULE_EXACT_ALARM
         couvre Android 12 (maxSdk 32) ; au-delà c'est USE_EXACT_ALARM qui prend le relais.
         Le planificateur dégrade proprement en alarme inexacte si l'exact est refusé. -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Re-planifier les alarmes après un redémarrage (elles ne survivent pas au reboot). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="${appLabel}"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="false"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.AgendaTech.Splash"
        tools:targetApi="34">

        <!-- Single Activity host (Compose). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|uiMode|locale|layoutDirection|keyboard|keyboardHidden|navigation|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AgendaTech.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Reminder alarm delivery. Reached only via an explicit PendingIntent from
             ReminderScheduler (no intent-filter needed), so exported=false. -->
        <receiver
            android:name=".system.alarm.ReminderReceiver"
            android:exported="false" />

        <!-- Reschedule reminder alarms after a reboot. BOOT_COMPLETED is a protected broadcast. -->
        <receiver
            android:name=".system.alarm.BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Home-screen widget (Glance). Exported so the launcher's AppWidgetHost can bind it. -->
        <receiver
            android:name=".widget.AgendaWidgetReceiver"
            android:exported="true"
            android:label="${appLabel}">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/agenda_widget_info" />
        </receiver>

        <!-- Compact 1×1 "icon-style" widget: weekday + day number + month. -->
        <receiver
            android:name=".widget.AgendaIconWidgetReceiver"
            android:exported="true"
            android:label="${appLabel}">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/agenda_icon_widget_info" />
        </receiver>
    </application>
</manifest>
